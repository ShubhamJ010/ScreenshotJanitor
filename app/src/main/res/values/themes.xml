<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Splash screen theme for ScreenshotJanitor.
      Uses Theme.SplashScreen for AndroidX compat, but overrides the
      platform-level android:windowSplashScreenBackground to follow
      the system's dynamic Material You color (via DeviceDefault's colorBackground).
      colorPrimary / colorOnPrimary are defined here so the launcher icon
      can resolve them on all API levels. Android 12+ overrides them with
      wallpaper-derived values for Material You icon theming.
    -->
    <style name="Theme.ssJanitor" parent="Theme.SplashScreen">
        <!-- Material You icon colors (fallback values for pre-Android 12) -->
        <item name="colorPrimary">#006E6D</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Icon shown in the splash circle -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/avd_auto_delete</item>
        <!-- Dynamic Material You background for splash icon -->
        <item name="windowSplashScreenIconBackgroundColor">?attr/colorPrimary</item>
        <item name="windowSplashScreenAnimationDuration">400</item>
        <!-- After splash, Compose takes over theming -->
        <item name="postSplashScreenTheme">@style/Theme.ssJanitor.Main</item>
        <!--
          Override the platform splash background to use the system's
          colorBackground (which is Material You dynamic on Android 12+).
          The android: prefix targets the real system splash screen on API 31+.
        -->
        <item name="android:windowSplashScreenBackground">?android:attr/colorBackground</item>
    </style>

    <!-- Post-splash theme: DeviceDefault picks up Material You dynamic colors -->
    <style name="Theme.ssJanitor.Main" parent="android:Theme.DeviceDefault.Light.NoActionBar" />

</resources>